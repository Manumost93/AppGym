# Copiar como .env.prod en el VPS, junto a docker-compose.prod.yml. Nunca commitear
# este archivo con valores reales (ver docs/deployment.md para la guia completa).

# Namespace de GHCR: normalmente tu usuario de GitHub en minusculas.
IMAGE_NAMESPACE=manumost93
IMAGE_TAG=latest

# Genera contrasenas y secretos unicos para produccion, por ejemplo con:
#   openssl rand -base64 32
POSTGRES_PASSWORD=CAMBIA_ESTO
AUTH_DB_PASSWORD=CAMBIA_ESTO
BUSINESS_DB_PASSWORD=CAMBIA_ESTO
BOOKING_DB_PASSWORD=CAMBIA_ESTO
JWT_SECRET=CAMBIA_ESTO_POR_ALGO_DE_AL_MENOS_32_CARACTERES

ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_CHAT=claude-haiku-4-5
CLAUDE_MODEL_RECOMMEND=claude-sonnet-5
CLAUDE_MODEL_INSIGHTS=claude-sonnet-5

# Dominio que apunta a la IP del VPS (ver docs/deployment.md si todavia no
# tienes uno propio: se puede usar <ip-con-guiones>.nip.io mientras tanto).
DOMAIN=api.tudominio.com
ACME_EMAIL=tu-email@ejemplo.com

# URL real del frontend desplegado (Vercel), para que el gateway acepte
# peticiones CORS solo desde ahi.
FRONTEND_ORIGIN=https://tu-portfolio.vercel.app
